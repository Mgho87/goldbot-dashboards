# Google Apps Script Web App URL (ends with /exec).
# 1. Google Sheet → Extensions → Apps Script.
# 2. Paste apps-script/Code.gs, Save.
# 3. Deploy → New deployment → Web app:
#       Execute as: Me   |   Who has access: Anyone
# 4. Copy the Web app URL and paste it below.
#
# No Google Sheets API, no API key, no credentials, no OAuth.
NEXT_PUBLIC_APPS_SCRIPT_URL=
